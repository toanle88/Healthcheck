# Postgres Database Connection String (internal compose network)
DATABASE_URL=postgres://postgres:postgres@postgres:5432/healthcheck?sslmode=disable

# API Settings
PORT=8080
ENV=development

# Entra ID Authentication (Azure AD)
ENTRA_TENANT_ID=your-entra-tenant-id-here
ENTRA_CLIENT_ID=your-entra-client-id-here

# Frontend Settings (Vite Build/Runtime Env Injection)
VITE_API_URL=http://localhost:8080
VITE_APP_VERSION=local-dev
VITE_ENTRA_CLIENT_ID=your-entra-client-id-here
VITE_ENTRA_TENANT_ID=your-entra-tenant-id-here

# --- BACKEND SETTINGS ---
PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/healthcheck?sslmode=disable
ENV=development
LOG_LEVEL=info

# --- ENTRA ID (Azure AD) SETTINGS ---
# Used by Backend to validate JWTs and Frontend to initialize MSAL
ENTRA_TENANT_ID=your-tenant-id-here
ENTRA_CLIENT_ID=your-client-id-here

# --- DOCKER SETTINGS ---
# Uncomment when running in docker-compose
# DATABASE_URL=postgres://postgres:postgres@postgres:5432/healthcheck?sslmode=disable
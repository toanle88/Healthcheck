# BUILD STAGE
FROM node:22-alpine AS builder
WORKDIR /app
RUN npm install -g pnpm
COPY package.json pnpm-lock.yaml ./
# Using pnpm with --ignore-scripts to bypass the v9 interactive approval hurdle
RUN pnpm install --ignore-scripts
COPY . .
# We build the production assets
RUN pnpm run build

# PRODUCTION STAGE
FROM nginx:alpine
# Copy the built files from the builder stage
COPY --from=builder /app/dist /usr/share/nginx/html
# Custom nginx config to handle React routing
RUN echo 'server { listen 80; location / { root /usr/share/nginx/html; index index.html; try_files $uri $uri/ /index.html; } }' > /etc/nginx/conf.d/default.conf

EXPOSE 80
# This magic command finds all JS files and replaces placeholders with actual environment variables from Azure
# We use simple shell form here to avoid parsing errors in Alpine
CMD sed -i "s|VITE_API_URL_PLACEHOLDER|$VITE_API_URL|g" /usr/share/nginx/html/assets/*.js || true && \
    sed -i "s|VITE_APP_VERSION_PLACEHOLDER|$VITE_APP_VERSION|g" /usr/share/nginx/html/assets/*.js || true && \
    nginx -g 'daemon off;'

# STAGE 1: Build the React static assets
FROM node:26-alpine AS web-builder
WORKDIR /app
RUN npm install -g pnpm
COPY package.json pnpm-lock.yaml ./
# Using pnpm with --ignore-scripts to bypass the v9 interactive approval hurdle
RUN pnpm install --ignore-scripts
COPY . .
RUN pnpm run build

# STAGE 2: Build the Go webserver
FROM golang:1.26-alpine AS server-builder
WORKDIR /app
COPY server/main.go ./server/
RUN CGO_ENABLED=0 GOOS=linux go build -o webserver ./server/main.go

# STAGE 3: Final Distroless Image
FROM gcr.io/distroless/static-debian12:nonroot
WORKDIR /app
COPY --from=web-builder --chown=nonroot:nonroot /app/dist ./dist
COPY --from=server-builder /app/webserver ./webserver

EXPOSE 8080
ENV PORT=8080
ENV DIST_DIR=/app/dist

USER nonroot:nonroot
ENTRYPOINT ["./webserver"]
